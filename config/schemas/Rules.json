{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Rules",
  "description": "Configuration defining phonological rules as Finite State Transducers (FSTs).",
  "type": "object",
  "required": [
    "kind",
    "rules"
  ],
  "properties": {
    "kind": {
      "type": "string",
      "enum": [
        "Rules"
      ]
    },
    "source_path": {
      "type": "string",
      "description": "The file path from which this config was loaded."
    },
    "rules": {
      "type": "object",
      "description": "A map of rule names to their definitions.",
      "additionalProperties": {
        "allOf": [
          {
            "oneOf": [
              {
                "description": "Simple context-sensitive rewrite rule.",
                "required": [
                  "input_pattern",
                  "output_pattern"
                ],
                "properties": {
                  "input_pattern": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "description": "The pattern to be replaced (null for insertion)."
                  },
                  "output_pattern": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "description": "The replacing pattern (null for deletion)."
                  }
                }
              },
              {
                "description": "A rule defined by a list of explicit string mappings.",
                "required": [
                  "string_map"
                ],
                "properties": {
                  "string_map": {
                    "type": "array",
                    "description": "A list of [input, output] string pairs.",
                    "items": {
                      "type": "array",
                      "minItems": 2,
                      "maxItems": 2,
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                }
              },
              {
                "description": "A rule defined as a sequence of other rules applied via composition.",
                "required": [
                  "rule_sequence"
                ],
                "properties": {
                  "rule_sequence": {
                    "type": "array",
                    "description": "List of rule names or file references (prefixed with $).",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            ]
          },
          {
            "properties": {
              "description": {
                "type": "string",
                "description": "A human-readable explanation of the rule's purpose."
              },
              "left_context": {
                "type": "string",
                "description": "Pattern that must appear to the left of the change."
              },
              "right_context": {
                "type": "string",
                "description": "Pattern that must appear to the right of the change."
              },
              "direction": {
                "type": "string",
                "enum": [
                  "ltr",
                  "rtl",
                  "sim"
                ],
                "description": "Direction of application (left-to-right, right-to-left, or simultaneous)."
              },
              "sigma_star": {
                "type": "string",
                "description": "Pattern defining the alphabet/language context (default usually Sigma*)."
              }
            }
          }
        ]
      }
    }
  },
  "additionalProperties": false
}