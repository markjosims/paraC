{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MorphemeSequence",
  "description": "Configuration for sequencing lexical and morphological elements.",
  "type": "object",
  "required": ["kind", "data"],
  "properties": {
    "source_path": {
      "type": "string",
      "description": "The file path from which this config was loaded."
    },
    "kind": {
      "type": "string",
      "enum": ["MorphemeSequence"]
    },
    "fixed_features": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "description": "Features that are fixed to specific values for this sequence."
    },
    "data": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "value"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["Lexicon", "Paradigm", "Pattern", "Rule", "MorphemeSet"]
          },
          "value": {
            "type": "string",
            "description": "Reference (starts with $) or inline value for Pattern."
          }
        },
        "if": {
          "properties": { "type": { "enum": ["Lexicon", "Paradigm", "Rule", "MorphemeSet"] } }
        },
        "then": {
          "properties": { "value": { "pattern": "^\\$.*" } }
        }
      }
    }
  }
}
