{
    "name": "parC Demo",
    "image": "mcr.microsoft.com/devcontainers/python:3.10",
    "postCreateCommand": "uv sync && parC",
    "containerEnv": {
        "YAML_DIR": "./yaml"
    },
    "features": {
        "ghcr.io/jsburckhardt/devcontainer-features/uv:1": {}
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "redhat.vscode-yaml",
                "rioj7.vscode-file-template",
                "sleistner.vscode-fileutils"
            ]
        }
    },
    "forwardPorts": [
        8000
    ]
}