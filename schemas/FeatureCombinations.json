{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/feature-combinations.schema.json",
  "title": "FeatureCombinations",
  "type": "object",
  "required": ["kind", "features", "combinations"],
  "additionalProperties": false,
  "properties": {
    "source_path": {
      "type": "string",
      "description": "The file path from which this config was loaded."
    },
    "kind": {
      "type": "string",
      "const": "FeatureCombinations"
    },
    "features": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "combinations": {"$ref": "#/definitions/combinations"}
  },
  "definitions": {
    "combinations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        }
      }
    }
  }
}