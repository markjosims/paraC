{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "inventory_schema.json",
  "title": "Inventory",
  "description": "Schema for phoneme and symbol inventory YAML configs",
  "type": "object",
  "required": [
    "kind",
    "data"
  ],
  "properties": {
    "source_path": {
      "type": "string",
      "description": "The file path from which this config was loaded."
    },
    "kind": {
      "type": "string",
      "const": "Inventory",
      "description": "Type identifier for inventory configs"
    },
    "data": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/inventoryNode"
      }
    }
  },
  "$defs": {
    "inventoryNode": {
      "type": "object",
      "description": "A node in the inventory tree, can contain phones, flags, ref, or child nodes",
      "properties": {
        "ref": {
          "type": "string",
          "pattern": "^<[^>]+>$",
          "description": "Representation symbol in angle brackets (e.g., <V>, <C>, <V_Mid>)"
        },
        "name": {
          "type": "string",
          "description": "Descriptive label for class"
        },
        "phones": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Array of phone symbols (IPA characters)"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^\\[[^\\]]+\\]$"
          },
          "description": "Array of tag symbols in square brackets"
        },
        "children": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/inventoryNode"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}